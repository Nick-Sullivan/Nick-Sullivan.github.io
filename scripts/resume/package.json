{
  "name": "resume",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "build": "mise exec -- typst compile --font-path ./node_modules/@fortawesome/fontawesome-free/webfonts --font-path ./node_modules/@expo-google-fonts/eb-garamond resume.typ",
    "watch": "mise exec -- typst watch --font-path ./node_modules/@fortawesome/fontawesome-free/webfonts --font-path ./node_modules/@expo-google-fonts/eb-garamond resume.typ"
  },
  "devDependencies": {
    "@expo-google-fonts/eb-garamond": "^0.4.2",
    "@fortawesome/fontawesome-free": "^6.7.2"
  }
}
