---
import NavColumn from "../components/NavColumn.astro";
import { ClientRouter } from "astro:transitions";
import { Font } from "astro:assets";
const { pageTitle, description, showTitle = true, fullWidth = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle} | Nick Sullivan</title>
    {description && <meta name="description" content={description} />}
    <ClientRouter />
    <Font cssVariable="--font-pt-serif" />
    <Font cssVariable="--font-caveat" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/fontawesome.min.css"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/solid.min.css"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/brands.min.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/fontawesome.min.css"
      />
      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/solid.min.css"
      />
      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/brands.min.css"
      />
    </noscript>
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="8b3578ce-5dd5-4c43-8f86-2a6e8adcf606"></script>
    <slot name="head" />
  </head>
  <body>
    <div class="layout-base">
      <NavColumn transition:persist />
      <main class="content-outer">
        {fullWidth ? (
          <slot />
        ) : (
          <div class="content-inner">
            {showTitle && <h1>{pageTitle}</h1>}
            <slot />
          </div>
        )}
      </main>
    </div>
  </body>
</html>

<style>
  /* Small screen */
  body {
    overflow: hidden;
  }
  .layout-base {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    height: 100vh;
    width: 100%;
  }
  .content-outer {
    display: flex;
    flex: 1;
    flex-direction: column;
    height: 100vh;
    overflow-y: auto;
    width: 100%;
    align-items: center;
    background-color: var(--bg-surface);
    scrollbar-color: var(--color-faint) var(--bg-wash);
  }

  .content-outer::-webkit-scrollbar {
    width: 8px;
  }

  .content-outer::-webkit-scrollbar-track {
    background: var(--bg-wash);
  }

  .content-outer::-webkit-scrollbar-thumb {
    background: var(--color-faint);
    border-radius: 4px;
  }

  .content-outer::-webkit-scrollbar-thumb:hover {
    background: var(--color-primary);
  }
  .content-inner {
    max-width: 1400px;
    width: 100%;
    box-sizing: border-box;
    padding: 3rem clamp(1.5rem, 5vw, 6rem);
  }
  .content-inner h1 {
    margin-top: 0;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #f0f0f0;
    color: #333;
  }

  .footnotes {
    scroll-margin-top: 20px;
  }
</style>
