---
import BaseLayout from "./BaseLayout.astro";
const { post, backUrl, backLabel } = Astro.props;

const date = new Date(post.data.date);
const day = date.getDate();
const month = date.toLocaleString("default", { month: "short" });
const year = date.getFullYear();
const daySuffix = (day: number) => {
  if (day > 3 && day < 21) return "th";
  switch (day % 10) {
    case 1:
      return "st";
    case 2:
      return "nd";
    case 3:
      return "rd";
    default:
      return "th";
  }
};
const dateStr = `${day}${daySuffix(day)} ${month} ${year}`;
---

<BaseLayout pageTitle={post.data.title} description={post.data.description}>
  <div class="meta-row">
    <div class="meta-left">
      <p class="date">
        <i class="fa-regular fa-calendar"></i>
        {dateStr}
      </p>
      <p class="description"><em>{post.data.description}</em></p>
    </div>
    {backUrl && <a href={backUrl} class="back-link">← {backLabel}</a>}
  </div>
  <slot />
  <div class="footer"></div>
</BaseLayout>

<style>
  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .meta-left {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .date {
    margin-top: 0;
    margin-bottom: 0;
  }
  .description {
    margin-top: 0;
    margin-bottom: 0;
  }
  .footer {
    height: 50px;
  }
  .back-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
    padding-top: 0.1rem;
  }
  .back-link:hover {
    color: var(--color-primary);
  }
</style>
