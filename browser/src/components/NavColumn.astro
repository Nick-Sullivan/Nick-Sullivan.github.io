---
const currentPath = Astro.url.pathname;
const links = [
  { href: "/", text: "Home", isActive: currentPath === "/" },
  { href: "/blog", text: "Blog", isActive: currentPath.startsWith("/blog") },
  {
    href: "/projects",
    text: "Projects",
    isActive: currentPath.startsWith("/projects"),
  },
  {
    href: "/contact",
    text: "Contact",
    isActive: currentPath.startsWith("/contact"),
  },
];
---

<div class="nav-column" id="nav-column">
  <div class="nav-header">
    <div class="logo-section">
      <img src="/favicon.ico" alt="Favicon" class="favicon" width="32" height="32" />
      <!-- <p class="nav-name">Nick Sullivan</p> -->
    </div>
    <button id="toggle-button" aria-label="Toggle navigation">
      <i class="fa-solid fa-bars" id="menu-icon"></i>
      <i class="fa-solid fa-times" id="close-icon" style="display: none;"></i>
    </button>
  </div>
  <nav class="nav-links">
    <ul>
      {
        links.map((link) => (
          <li>
            <a href={link.href} class={link.isActive ? "active" : ""}>
              {link.text}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</div>

<script>
  const toggleButton = document.getElementById("toggle-button");
  const navColumn = document.getElementById("nav-column");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  if (toggleButton && navColumn && menuIcon && closeIcon) {
    toggleButton.addEventListener("click", function () {
      const isOpen = navColumn.classList.toggle("fullscreen");

      if (isOpen) {
        menuIcon.style.display = "none";
        closeIcon.style.display = "block";
      } else {
        menuIcon.style.display = "block";
        closeIcon.style.display = "none";
      }
    });
  }
</script>

<style>
  /* Small Screen */
  .nav-column {
    display: flex;
    flex-direction: column;
    width: 100%;
    background-color: #ffffff;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", "Oxygen",
      "Ubuntu", "Cantarell", sans-serif;
  }

  .nav-column.fullscreen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    background-color: #ffffff;
    overflow: auto;
  }

  .nav-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e5e5e5;
    align-items: center;
    background-color: #ffffff;
  }

  .logo-section {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-name {
    display: block;
    font-weight: 600;
    color: #1a1a1a;
    font-size: 1.1rem;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .favicon {
    display: block;
    width: 32px;
    height: 32px;
    border-radius: 50%;
  }

  .nav-column ul {
    display: none;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-column.fullscreen ul {
    display: flex;
    flex-direction: column;
    padding: 24px 20px;
    gap: 8px;
  }

  .nav-column li {
    width: 100%;
  }

  nav a {
    color: #5c5962;
    display: block;
    text-align: left;
    width: 100%;
    border: none;
    background: none;
    padding: 16px 20px;
    text-decoration: none;
    transition: all 0.2s ease;
    font-weight: 500;
    font-size: 1.1rem;
    border-radius: 8px;
  }

  nav a:hover {
    background-color: #f8f7ff;
    color: #7253ef;
    transform: translateX(4px);
  }

  nav a.active {
    font-weight: 600;
    color: #ffffff;
    background-color: #7253ef;
    box-shadow: 0 2px 8px rgba(114, 83, 239, 0.25);
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: #ffffff;
  }

  .nav-links ul {
    width: 100%;
  }

  #toggle-button {
    border: none;
    outline: none;
    background: none;
    font-size: 1.5rem;
    color: #333;
    cursor: pointer;
    padding: 8px;
    border-radius: 6px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
  }

  #toggle-button:hover {
    background-color: #f0f0f0;
  }

  #toggle-button:active {
    transform: scale(0.95);
  }

  #close-icon {
    color: #7253ef;
  }

  /* Large Screen */
  @media screen and (min-width: 800px) {
    .nav-column {
      display: flex;
      flex-direction: column;
      width: 240px;
      height: 100%;
      background-color: #ffffff;
      border-right: 1px solid #e5e5e5;
      transition: width 0.3s ease;
      overflow: hidden;
    }

    .nav-header {
      display: flex;
      flex-direction: column;
      padding: 32px 24px;
      border-bottom: 1px solid #e5e5e5;
      align-items: center;
      gap: 12px;
      background-color: #ffffff;
    }

    .logo-section {
      flex-direction: column;
      gap: 12px;
    }

    .nav-name {
      display: block;
      font-size: 1.35rem;
      text-align: center;
      white-space: nowrap;
      font-weight: 600;
      color: #1a1a1a;
      letter-spacing: -0.02em;
    }

    .favicon {
      display: block;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .nav-column ul {
      list-style: none;
      padding: 16px 0;
      width: 100%;
      display: block;
      margin: 0;
    }

    .nav-column li {
      width: 100%;
      margin-bottom: 4px;
    }

    nav a {
      margin: 0 12px;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 1rem;
    }

    nav a:hover {
      background-color: #f8f7ff;
      color: #7253ef;
      transform: translateX(4px);
    }

    nav a.active {
      background-color: #7253ef;
      color: #ffffff;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(114, 83, 239, 0.25);
    }

    #toggle-button {
      display: none;
    }
  }
</style>
