---
const { url, title, date } = Astro.props;

const day = date.getDate();
const month = date.toLocaleString("default", { month: "short" });
const daySuffix = (day: number) => {
  if (day > 3 && day < 21) return "th";
  switch (day % 10) {
    case 1:
      return "st";
    case 2:
      return "nd";
    case 3:
      return "rd";
    default:
      return "th";
  }
};
const dateStr = `${day}${daySuffix(day)} ${month}`;
---

<a href={url} class="blog-link">
  <span class="title">{title}</span>
  <span class="date">{dateStr}</span>
</a>

<style>
  .blog-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    margin-bottom: 8px;
    border-radius: 8px;
    background: #fafafa;
    border-left: 3px solid transparent;
    text-decoration: none;
    transition: all 0.2s ease;
    width: 100%;
    box-sizing: border-box;
  }

  .blog-link:hover {
    background: #f0f0f0;
    border-left-color: #7253ef;
    transform: translateX(4px);
  }

  .title {
    color: #333;
    font-weight: 500;
    font-size: 1.05em;
  }

  .date {
    font-size: 0.85em;
    color: #666;
    font-family: monospace;
    white-space: nowrap;
  }
</style>
