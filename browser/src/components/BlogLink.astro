---
const { url, title, date, description } = Astro.props;

const day = date.getDate();
const month = date.toLocaleString("default", { month: "short" });
const year = date.getFullYear();
const daySuffix = (day: number) => {
  if (day > 3 && day < 21) return "th";
  switch (day % 10) {
    case 1: return "st";
    case 2: return "nd";
    case 3: return "rd";
    default: return "th";
  }
};
const dateStr = `${day}${daySuffix(day)} ${month} ${year}`;
const hasDescription = description && description.trim() && description !== "asdf";
---

<a href={url} class="post-row">
  <span class="post-title">{title}</span>
  <span class="post-date">{dateStr}</span>
  {hasDescription && <span class="post-description">{description}</span>}
</a>

<style>
  .post-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.3;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .post-row:hover .post-title {
    color: var(--color-primary);
  }

  .post-description {
    font-size: 0.95rem;
    color: var(--text-soft);
    line-height: 1.5;
    margin-top: 0.1rem;
  }
</style>
