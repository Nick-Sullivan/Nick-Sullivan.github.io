---
const { url, title, date, description, image, imageFit = "cover" } = Astro.props;

const month = date.toLocaleString("default", { month: "short" });
const year = date.getFullYear();
const dateStr = `${month} ${year}`;
const hasDescription = description && description.trim() && description !== "asdf";
---

<a href={url} class="post-row">
  {image && (
    <div class="post-image">
      <img src={image.src} alt={title} loading="lazy" style={`object-fit: ${imageFit}`} />
    </div>
  )}
  {!image && <div class="post-image post-image--empty" />}
  <div class="post-text">
    <span class="post-title">{title}</span>
    <span class="post-date">{dateStr}</span>
    {hasDescription && <span class="post-description">{description}</span>}
  </div>
</a>

<style>
  .post-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }

  .post-image {
    flex-shrink: 0;
    width: 200px;
    height: 130px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-image-bg);
  }

  .post-image--empty {
    background: #f0edff;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .post-row:hover .post-image img {
    transform: scale(1.03);
  }

  .post-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: 0.2rem;
  }

  .post-date {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1.3;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .post-row:hover .post-title {
    color: var(--color-primary);
  }

  .post-description {
    font-size: 0.95rem;
    color: var(--text-soft);
    line-height: 1.5;
    margin-top: 0.15rem;
  }

  @media (max-width: 560px) {
    .post-image {
      width: 110px;
      height: 72px;
    }
  }
</style>
