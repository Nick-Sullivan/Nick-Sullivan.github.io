---
const { testimonial, author, role } = Astro.props;
---

<figure class="testimonial">
  <blockquote class="testimonial-body">
    <span class="quote-mark">"</span>{testimonial}"
  </blockquote>
  <figcaption class="testimonial-author">
    <span class="author-dash">—</span>
    <span class="author-name">{author}{role && <span class="author-role">, {role}</span>}</span>
  </figcaption>
</figure>

<style>
  .testimonial {
    margin: 0;
    padding: 0;
  }

  .testimonial-body {
    margin: 0 0 1rem 0;
    padding: 0;
    border: none;
    background: none;
    font-style: italic;
    color: var(--text-warm);
    line-height: 1.8;
    font-size: 1rem;
    position: relative;
  }

  .quote-mark {
    font-size: 3.5rem;
    line-height: 0;
    vertical-align: -0.6em;
    color: var(--color-faint);
    font-family: Georgia, serif;
    margin-right: 0.1em;
  }

  .testimonial-author {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .author-dash {
    color: var(--color-faint);
    font-size: 1rem;
    flex-shrink: 0;
  }

  .author-name {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-heading);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .author-role {
    font-weight: 400;
    color: var(--text-muted);
  }
</style>
